Windows Registry Editor Version 5.00

; Korean-Japanese IME — TSF TIP profile registration with full Category set
; (mirrors what Microsoft's standard Korean IME registers).
;
; Apply this AFTER `regsvr32 KorJpnIme.dll`, then LOG OUT and LOG IN.
; ctfmon picks up TIP entries at session start; with Enable=0 + proper
; Category metadata + KeyHandler::Advise(BG) the IME stays passive until the
; user explicitly switches to it via Win+Space or Settings.

[HKEY_LOCAL_MACHINE\SOFTWARE\Microsoft\CTF\TIP\{CADA0001-1234-5678-90AB-CDEF00000001}]

; ----- Category metadata (declares us as a keyboard TIP with standard caps) ---
; The Category subtree has BOTH directions: Category\{CATGUID}\{CLSID} AND Item\{CLSID}\{CATGUID}.
; CATGUIDs (from MS Korean IME):
;   {046B8C80-1647-40F7-9B21-B93B81AABC1B}  GUID_TFCAT_TIP_KEYBOARD       — keyboard TIP
;   {13A016DF-560B-46CD-947A-4C3AF1E0E35D}  GUID_TFCAT_DISPLAYATTRIBUTEPROVIDER
;   {25504FB4-7BAB-4BC1-9C69-CF81890F0EF5}  GUID_TFCAT_PROPSTYLE_STATIC
;   {34745C63-B2F0-4784-8B67-5E12C8701A31}  GUID_TFCAT_TIPCAP_INPUTMODECOMPARTMENT
;   {364215D9-75BC-11D7-A6EF-00065B84435C}  GUID_TFCAT_TIPCAP_UIELEMENTENABLED
;   {3AF314A2-D79F-4B1B-9992-15086D339B05}  GUID_TFCAT_TIPCAP_SECUREMODE
;   {49D2F9CE-1F5E-11D7-A6D3-00065B84435C}  GUID_TFCAT_TIPCAP_IMMERSIVESUPPORT
;   {49D2F9CF-1F5E-11D7-A6D3-00065B84435C}  GUID_TFCAT_TIPCAP_SYSTRAYSUPPORT
;   {CCF05DD7-4A87-11D7-A6E2-00065B84435C}  GUID_TFCAT_TIPCAP_COMLESS

[HKEY_LOCAL_MACHINE\SOFTWARE\Microsoft\CTF\TIP\{CADA0001-1234-5678-90AB-CDEF00000001}\Category]
[HKEY_LOCAL_MACHINE\SOFTWARE\Microsoft\CTF\TIP\{CADA0001-1234-5678-90AB-CDEF00000001}\Category\Category]

[HKEY_LOCAL_MACHINE\SOFTWARE\Microsoft\CTF\TIP\{CADA0001-1234-5678-90AB-CDEF00000001}\Category\Category\{046B8C80-1647-40F7-9B21-B93B81AABC1B}]
