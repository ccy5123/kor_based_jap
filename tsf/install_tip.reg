[HKEY_LOCAL_MACHINE\SOFTWARE\Microsoft\CTF\TIP\{CADA0001-1234-5678-90AB-CDEF00000001}\LanguageProfile]
[HKEY_LOCAL_MACHINE\SOFTWARE\Microsoft\CTF\TIP\{CADA0001-1234-5678-90AB-CDEF00000001}\LanguageProfile\0x00000412]

